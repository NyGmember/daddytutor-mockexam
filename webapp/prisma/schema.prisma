generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subject {
  id     String  @id
  nameTh String
  levels Level[]
}

model Level {
  id        String     @id // e.g. "primary", "lower_secondary", "upper_secondary"
  nameTh    String
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id])
  topics    Topic[]
  questions Question[]
}

model Topic {
  id        String     @id // e.g. "basic_physics"
  nameTh    String
  levelId   String
  level     Level      @relation(fields: [levelId], references: [id])
  questions Question[]
}

model Question {
  id            String   @id // e.g. "TEDET_Sci_2557_G9_20"
  subjectId     String
  levelId       String
  topicId       String
  year          Int
  difficulty    Int      // 1 to 5 stars
  questionText  String   // Markdown with LaTeX
  answerText    String   // Markdown with LaTeX (Explanation)
  correctAnswer String   // e.g. "3"
  images        String   // JSON string of image filenames, e.g., '["img1.png"]'
  level         Level    @relation(fields: [levelId], references: [id])
  topic         Topic    @relation(fields: [topicId], references: [id])
}

model SyncLog {
  version  String   @id // e.g. "1.0.0"
  syncedAt DateTime @default(now())
}
